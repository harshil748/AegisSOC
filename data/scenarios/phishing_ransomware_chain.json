{
  "scenario_id": "phishing_ransomware_chain",
  "name": "Phishing to Ransomware Attack Chain",
  "description": "A finance analyst (Elena Martinez, WKSTN-1147) receives a spoofed invoice email with a macro-enabled Word document from secure-office365-update.com. Opening the attachment spawns an obfuscated PowerShell stager that downloads a second-stage payload, dumps LSASS to harvest a domain-admin credential, moves laterally via PsExec/WMI to the file and SQL servers, and finally deploys ransomware that encrypts finance shares with the .aegislock extension and drops a ransom note. Represents the full kill chain: initial access -> execution -> credential access -> lateral movement -> impact.",
  "expected_severity": "critical",
