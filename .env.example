# Copy to .env and fill in real values for local development.
# NEVER commit a real .env file — it is git-ignored by default.

# --- General ---
ENVIRONMENT=local
TENANT_ID=default
LOG_LEVEL=INFO

# AEGIS_SYNC_MODE controls whether the data-path services communicate
# synchronously over HTTP (sync — simplest for tests/CI without Kafka) or
# asynchronously over Kafka/Redpanda topics (async — production-shaped).
AEGIS_SYNC_MODE=async

# --- Datastores ---
NEO4J_PASSWORD=aegispassword
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis
POSTGRES_DB=aegis


# --- Auth ---
JWT_SECRET=dev-only-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- LLM (llm_triage) ---
LLM_ENABLED=true
LLM_MODEL=gpt-4o-mini
LLM_MAX_EVIDENCE_ITEMS=40
OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Observability ---
GRAFANA_ADMIN_PASSWORD=admin

# --- Threat intel (enrichment) — optional, MVP works without these ---
OPENCTI_URL=
OPENCTI_API_KEY=
MISP_URL=
MISP_API_KEY=
VIRUSTOTAL_API_KEY=
